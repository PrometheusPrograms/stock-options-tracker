# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── Environment ──────────────────────────────────────────────────────────────
# Options: development | test | production
APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
# Set this in each PythonAnywhere site's Web tab → Environment variables.
#   Local dev:  trades.db
#   PA test:    /home/greenmandev/inv_track/trades_test.db
#   PA prod:    /home/greenmangroup/inv_track/trades.db
DB_PATH=trades.db

# ── Schwab API ────────────────────────────────────────────────────────────────
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here
SCHWAB_REDIRECT_URI=http://localhost:5005/auth/schwab/callback
SCHWAB_TOKEN_FILE=schwab_tokens.json
